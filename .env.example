# ─────────────────────────────────────────────
#  EcoLens — Environment Variables (Template)
#  Copy to .env.local and fill in real values.
#  NEVER commit .env.local or any .env.* file.
# ─────────────────────────────────────────────

# ── Auth0 (User Auth) ──────────────────────────────────────────────────────────
# Dashboard: https://manage.auth0.com → Applications → your app
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://api.ecolens.app

# nextjs-auth0 SDK session encryption secret (32+ random chars)
# Generate: openssl rand -hex 32
AUTH0_SECRET=

# App base URL (http://localhost:3000 in dev, https://ecolens.vercel.app in prod)
AUTH0_BASE_URL=http://localhost:3000

# ── Auth0 AI Agents (Machine-to-Machine) ──────────────────────────────────────
# Dashboard: Applications → Machine to Machine → your agent app
# Scopes: read:products invoke:llm write:scores read:external invoke:voice
AUTH0_M2M_CLIENT_ID=
AUTH0_M2M_CLIENT_SECRET=

# ── Google Gemini (3 keys — delegated per agent to avoid free tier exhaustion) ─
# console.cloud.google.com → APIs → Gemini API → Credentials
# Model: gemini-2.0-flash
# KEY_1 → GeminiResearch agent  (product sustainability research, most frequent)
# KEY_2 → ScoreAggregator agent (reasoning + explanation generation)
# KEY_3 → RecommendationEngine + VoiceNarrator text (least frequent)
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# ── ElevenLabs ─────────────────────────────────────────────────────────────────
# elevenlabs.io → Profile → API Key
# Voice ID: pick a warm conversational voice from the Voice Library
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Supabase ───────────────────────────────────────────────────────────────────
# supabase.com → Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # Backend + seed scripts only — NEVER expose to browser

# ── SerpAPI ────────────────────────────────────────────────────────────────────
# serpapi.com → Dashboard → API Key (100 free searches/month)
SERP_API_KEY=

# ── Backend ────────────────────────────────────────────────────────────────────
# FastAPI backend URL (http://localhost:8000 in dev, Railway URL in prod)
NEXT_PUBLIC_API_URL=http://localhost:8000
